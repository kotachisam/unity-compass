---
import Layout from "@/layouts/Layout.astro"
import SearchResults from "@/components/react/SearchResults"

const url = new URL(Astro.request.url)
const q = url.searchParams.get("q") ?? ""
---

<Layout title={q ? `Search: ${q}` : "Search"}>
  <div class="wiki-content-area">
    <article class="wiki-article">
      <h1>Search</h1>
      <p style="color: var(--wiki-border); font-size: 13px; margin-bottom: 16px;">
        Press <kbd>⌘K</kbd> anywhere to open the search palette for quick navigation. This page renders full results for browsing.
      </p>
      <SearchResults client:load initialQuery={q} />
    </article>
  </div>
</Layout>
