---
import Layout from "@/layouts/Layout.astro"
import MiniGraphIsland from "@/components/MiniGraphIsland"
import { getAllArticles, getArticleBySlug, getBacklinks } from "@/lib/articles"
import { extractHeadings } from "@/lib/wikilinks"
import { slugify } from "@/lib/utils"
import { getSourceReferencesForArticle } from "@/lib/repo-scanner"
import { render } from "astro:content"

export async function getStaticPaths() {
  const all = await getAllArticles()
  const stubs = all.map((a) => ({ slug: a.id, title: a.data.title }))
  return all.map((a) => ({
    params: { slug: a.id },
    props: { stubs },
  }))
}

const { slug } = Astro.params
const { stubs } = Astro.props as { stubs: { slug: string; title: string }[] }
const article = await getArticleBySlug(slug!)
if (!article) {
  return Astro.redirect("/404")
}

const { Content } = await render(article)
const headings = extractHeadings(article.body ?? "")
const backlinks = await getBacklinks(slug!)
const sourceRefs = getSourceReferencesForArticle(slug!, stubs)
---

<Layout title={`${article.data.title} — Unity Compass Wiki`} description={article.data.description}>
  <div class="wiki-tab-bar">
    <div class="wiki-tabs-left">
      <span class="wiki-tab active">Article</span>
    </div>
    <div class="wiki-tabs-right">
      <span class="wiki-tab active">Read</span>
      <a
        class="wiki-tab"
        href={`https://github.com/kotachisam/unity-compass/blob/main/wiki/src/content/articles/${slug}.md`}
        target="_blank"
        rel="noopener noreferrer"
      >
        View source
      </a>
    </div>
  </div>

  <div class="wiki-content-area">
    <article class="wiki-article" data-pagefind-body data-pagefind-meta={`title:${article.data.title}`}>
      <h1>
        {article.data.title}
        <span class="wiki-article-type">({article.data.type})</span>
      </h1>

      <Content />

      {article.data.tags.length > 0 && (
        <div class="wiki-categories">
          <span>Categories:</span>
          {article.data.tags.map((tag: string) => (
            <a href={`/search?q=${encodeURIComponent(tag)}`}>{tag}</a>
          ))}
        </div>
      )}

      <section class="wiki-mini-graph">
        <h3 id="neighbourhood">Neighbourhood</h3>
        <p>
          1-hop neighbourhood from this article. Click another node to navigate. Click a Wikidata ghost (dashed) to open it externally.
        </p>
        <MiniGraphIsland client:visible slug={slug!} radius={1} />
      </section>

      {backlinks.length > 0 && (
        <details class="wiki-backlinks wiki-collapsible" id="what-links-here">
          <summary>
            <span class="wiki-collapsible-label">What links here</span>
            <span class="wiki-collapsible-count">{backlinks.length}</span>
          </summary>
          <ul>
            {backlinks.map((b) => (
              <li>
                <a href={`/wiki/${b.id}`}>{b.data.title}</a>
                <span class="wiki-backlink-type">({b.data.type})</span>
              </li>
            ))}
          </ul>
        </details>
      )}

      {sourceRefs.length > 0 && (
        <details class="wiki-source-refs wiki-collapsible wiki-collapsible-muted" id="referenced-in-source-documents">
          <summary>
            <span class="wiki-collapsible-label">Referenced in source documents</span>
            <span class="wiki-collapsible-count">{sourceRefs.length}</span>
          </summary>
          <ul>
            {sourceRefs.map((ref) => (
              <li>
                <a href={`/source/${ref.path}`}>{ref.title}</a>
                <span class="source-path"> ({ref.path})</span>
              </li>
            ))}
          </ul>
        </details>
      )}
    </article>

    <aside class="wiki-right-sidebar" data-aside>
      <div class="wiki-aside-toolbar">
        <span class="wiki-aside-toolbar-label">Page metadata</span>
        <button type="button" class="wiki-aside-master-btn" data-aside-toggle aria-expanded="true">
          Collapse all
        </button>
      </div>
      {headings.length > 0 && (
        <details class="wiki-aside-section" open>
          <summary>Contents</summary>
          <ul class="wiki-aside-toc">
            {headings.map((h) => (
              <li class={h.level === 3 ? "toc-h3" : ""}>
                <a href={`#${h.id}`}>{h.text}</a>
              </li>
            ))}
          </ul>
        </details>
      )}

      <details class="wiki-aside-section" open>
        <summary>Page info</summary>
        <dl class="wiki-aside-info">
          <dt>Type</dt><dd>{article.data.type}</dd>
          {article.data.created && (<><dt>Created</dt><dd>{article.data.created}</dd></>)}
          {article.data.last_updated && (<><dt>Updated</dt><dd>{article.data.last_updated}</dd></>)}
          {article.data.wikidata_qid && (<><dt>Wikidata</dt><dd><a href={`https://www.wikidata.org/wiki/${article.data.wikidata_qid}`} target="_blank" rel="noopener noreferrer">{article.data.wikidata_qid}</a></dd></>)}
          {backlinks.length > 0 && (<><dt>Backlinks</dt><dd><a href="#what-links-here">{backlinks.length}</a></dd></>)}
          {sourceRefs.length > 0 && (<><dt>Source refs</dt><dd><a href="#referenced-in-source-documents">{sourceRefs.length}</a></dd></>)}
        </dl>
      </details>

      {article.data.related.length > 0 && (
        <details class="wiki-aside-section" open>
          <summary>Related <span class="wiki-aside-count">{article.data.related.length}</span></summary>
          <ul class="wiki-aside-list">
            {article.data.related.map((r: string) => (
              <li>
                <a href={`/wiki/${slugify(r)}`}>{r}</a>
              </li>
            ))}
          </ul>
        </details>
      )}

      {article.data.sources.length > 0 && (
        <details class="wiki-aside-section">
          <summary>Sources <span class="wiki-aside-count">{article.data.sources.length}</span></summary>
          <ul class="wiki-aside-list wiki-aside-list-mono">
            {article.data.sources.map((s: string) => (
              <li>{s}</li>
            ))}
          </ul>
        </details>
      )}

      <details class="wiki-aside-section">
        <summary>Actions</summary>
        <ul class="wiki-aside-list">
          <li>
            <a
              href={`https://github.com/kotachisam/unity-compass/blob/main/wiki/src/content/articles/${slug}.md`}
              target="_blank"
              rel="noopener noreferrer"
            >
              View source on GitHub
            </a>
          </li>
          <li>
            <a href="/">Open in graph view</a>
          </li>
        </ul>
      </details>
    </aside>
  </div>

  <script is:inline>
    ;(function () {
      const aside = document.querySelector("[data-aside]")
      const btn = document.querySelector("[data-aside-toggle]")
      if (!aside || !btn) return
      const sections = aside.querySelectorAll("details.wiki-aside-section")

      function syncLabel() {
        const anyOpen = Array.from(sections).some((s) => s.open)
        btn.textContent = anyOpen ? "Collapse all" : "Expand all"
        btn.setAttribute("aria-expanded", anyOpen ? "true" : "false")
      }

      btn.addEventListener("click", () => {
        const anyOpen = Array.from(sections).some((s) => s.open)
        sections.forEach((s) => {
          s.open = !anyOpen
        })
        syncLabel()
      })

      sections.forEach((s) =>
        s.addEventListener("toggle", syncLabel)
      )

      syncLabel()
    })()

    ;(function () {
      function openDetailsFromHash() {
        const hash = window.location.hash.slice(1)
        if (!hash) return
        const target = document.getElementById(hash)
        if (target && target.tagName === "DETAILS") {
          target.open = true
          target.scrollIntoView({ behavior: "smooth", block: "start" })
        }
      }
      window.addEventListener("hashchange", openDetailsFromHash)
      openDetailsFromHash()
    })()
  </script>
</Layout>
