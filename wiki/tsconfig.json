{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["bun"]
  },
  "include": ["src/**/*", "scripts/**/*", "astro.config.mjs", ".astro/types.d.ts"],
  "exclude": ["node_modules", "dist", "app", "components", "lib"]
}
